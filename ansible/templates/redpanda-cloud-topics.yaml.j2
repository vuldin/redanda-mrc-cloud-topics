# Redpanda configuration for Cloud Topics with GCS
# This template documents the expected cloud storage config.
# The redpanda.cluster.redpanda_broker role auto-configures cloud storage
# when tiered_storage_bucket_name is set and cloud_storage_credentials_source
# is gcp_instance_metadata. The role auto-sets:
#   cloud_storage_enabled: true
#   cloud_storage_api_endpoint: storage.googleapis.com
#   cloud_storage_bucket: <tiered_storage_bucket_name>
#
# The following is for reference / manual override if needed:
#
# redpanda:
#   cloud_storage_enabled: true
#   cloud_storage_disable_tls: false
#   cloud_storage_api_endpoint: storage.googleapis.com
#   cloud_storage_api_endpoint_port: 443
#   cloud_storage_bucket: "{{ gcs_bucket_name }}"
#   cloud_storage_region: "{{ cloud_storage_region }}"
#   cloud_storage_credentials_source: gcp_instance_metadata
#   enable_rack_awareness: true
#   raft_heartbeat_interval_ms: 500
#   election_timeout_ms: 5000
